# SWAG / Let's Encrypt config
DOMAIN=example.com
SUBDOMAIN=ctfd
TZ=America/New_York

# Cloudflare DNS validation
# Create a file at conf/swag/dns-conf/cloudflare.ini with:
#   dns_cloudflare_api_token = YOUR_TOKEN
# Or set the token here and it will be passed via environment:
CF_API_TOKEN=your_cloudflare_api_token_here

# MariaDB
MARIADB_ROOT_PASSWORD=ctfd
MARIADB_USER=ctfd
MARIADB_PASSWORD=ctfd
MARIADB_DATABASE=ctfd

# SMTP (e.g. SMTP2GO)
# MAILFROM_ADDR=noreply@example.com
# MAIL_SERVER=mail.smtp2go.com
# MAIL_PORT=2525
# MAIL_USEAUTH=true
# MAIL_USERNAME=your_smtp2go_username
# MAIL_PASSWORD=your_smtp2go_password
# MAIL_TLS=true
# MAIL_SSL=false
