#: CTFd/auth.py:158
msgid "Please pick a longer password"
msgstr "Wybierz dłuższe hasło"

#: CTFd/auth.py:198 CTFd/auth.py:229
msgid "If that account exists you will receive an email, please check your inbox"
msgstr ""
"Jeśli to konto istnieje, otrzymasz wiadomość e-mail. Sprawdź swoją "
"skrzynkę odbiorczą."

#: CTFd/auth.py:208
msgid ""
"The email address associated with this account was registered via an "
"authentication provider and does not have an associated password. Please "
"login via your authentication provider."
msgstr ""
"Adres e-mail powiązany z tym kontem został zarejestrowany za "
"pośrednictwem dostawcy uwierzytelniania i nie ma przypisanego hasła. "
"Zaloguj się za pośrednictwem swojego dostawcy uwierzytelniania."

#: CTFd/auth.py:220
msgid "Too many password reset attempts. Please try again later."
msgstr "Zbyt wiele prób zresetowania hasła. Spróbuj ponownie później."

#: CTFd/auth.py:285
msgid "The registration code you entered was incorrect"
msgstr "Wprowadzony kod rejestracyjny jest nieprawidłowy"

#: CTFd/auth.py:296
msgid "Please provide all required fields"
msgstr "Wypełnij wszystkie wymagane pola"

