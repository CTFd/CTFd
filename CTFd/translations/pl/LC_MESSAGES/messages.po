#: CTFd/auth.py:352
msgid "Pick a shorter password"
msgstr "Wybierz krótsze hasło"

#: CTFd/auth.py:354
msgid "Pick a longer user name"
msgstr "Wybierz dłuższą nazwę użytkownika"

#: CTFd/auth.py:357
msgid "Websites must be a proper URL starting with http or https"
msgstr ""
"Strona internetowa musi być prawidłowym adresem URL rozpoczynającym się "
