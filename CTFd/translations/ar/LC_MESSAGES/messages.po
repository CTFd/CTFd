msgid "Pick a longer password"
msgstr "اختر كلمة مرور أطول"

#: CTFd/auth.py:352
msgid "Pick a shorter password"
msgstr "اختر كلمة مرور أقصر"

#: CTFd/auth.py:354
msgid "Pick a longer user name"
