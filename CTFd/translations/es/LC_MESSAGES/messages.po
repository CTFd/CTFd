msgid "The registration code you entered was incorrect"
msgstr "El código de registro que ingresó es incorrecto"

#: CTFd/auth.py:296
msgid "Please provide all required fields"
msgstr "Por favor complete todos los campos obligatorios"

#: CTFd/auth.py:334
msgid "Please enter a valid email address"
msgstr "Por favor ingrese una dirección de correo electrónico válida"

#: CTFd/auth.py:336 CTFd/auth.py:338
msgid "Your email address is not from an allowed domain"
msgstr "Su dirección de correo electrónico no pertenece a un dominio permitido"

