msgstr "Ese correo electrónico ya fue utilizado"

#: CTFd/auth.py:346
msgid "Pick a longer password"
msgstr "Elija una contraseña más larga"

#: CTFd/auth.py:352
msgid "Pick a shorter password"
msgstr "Elija una contraseña más corta"

#: CTFd/auth.py:354
msgid "Pick a longer user name"
msgstr "Elija un nombre de usuario más largo"

#: CTFd/auth.py:357
msgid "Websites must be a proper URL starting with http or https"
msgstr "Los sitios web deben ser una URL válida que comience con http o https"

