msgid "Pick a longer password"
msgstr "Выберите пароль подлиннее"

#: CTFd/auth.py:352
msgid "Pick a shorter password"
msgstr "Выберите пароль покороче"

#: CTFd/auth.py:354
msgid "Pick a longer user name"
msgstr "Выберите имя пользователя подлиннее"

